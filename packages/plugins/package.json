{
  "name": "@gameagent/plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Plugin registry and built-in plugins for GameAgent",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts",
      "types": "./dist/index.d.ts"
    },
    "./pong": {
      "source": "./src/pong/index.ts",
      "import": "./dist/pong/index.js",
      "default": "./src/pong/index.ts",
      "types": "./dist/pong/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rimraf dist *.tsbuildinfo",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@gameagent/game-core": "*",
    "@gameagent/ai-core": "*"
  },
  "devDependencies": {
    "typescript": "*",
    "rimraf": "*"
  }
}
