{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "noEmit": true,
    "composite": false,
    "allowImportingTsExtensions": true,
    "paths": {
      "@gameagent/plugins": ["../../packages/plugins/src/index.ts"],
      "@gameagent/game-core": ["../../packages/game-core/src/index.ts"],
      "@gameagent/ai-core": ["../../packages/ai-core/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/plugins/src/**/*",
    "../../packages/game-core/src/**/*",
    "../../packages/ai-core/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
